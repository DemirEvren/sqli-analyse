# ─── terraform.tfvars.example ─────────────────────────────────────────────────
# Safe to commit — no real credentials.
# Copy to terraform.tfvars and fill in your values.
# Sensitive variables (postgres_password, jwt_secret, github_token) must be
# passed via TF_VAR_* environment variables, NOT put in any .tfvars file.
# ─────────────────────────────────────────────────────────────────────────────

cloud_provider = "azure"

# ── Azure ─────────────────────────────────────────────────────────────────────
azure_subscription_id    = ""                 # e.g. "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
azure_location           = "westeurope"
azure_location_secondary = "northeurope"

# ── Project ───────────────────────────────────────────────────────────────────
project     = "shelfware"
environment = "prod"

tags = {
  team    = "platform"
  project = "shelfware"
}

# ── AKS — App Cluster ─────────────────────────────────────────────────────────
# Mirrors k3d: 1 server (D2s_v3) + 2 agents (D4s_v3 × min 2)
app_cluster_name                = "shelfware-app"
app_cluster_kubernetes_version  = "1.30"
app_cluster_system_node_count   = 1
app_cluster_system_node_vm_size = "Standard_D2s_v3"
app_cluster_user_node_min       = 2
app_cluster_user_node_max       = 5
app_cluster_user_node_vm_size   = "Standard_D4s_v3"

# ── AKS — Loadtest Cluster ────────────────────────────────────────────────────
loadtest_cluster_name               = "shelfware-loadtest"
loadtest_cluster_kubernetes_version = "1.30"
loadtest_cluster_node_count         = 1
loadtest_cluster_node_vm_size       = "Standard_D2s_v3"

# ── ACR ───────────────────────────────────────────────────────────────────────
acr_sku                     = "Premium"
acr_geo_replication_enabled = false

# ── Monitoring ────────────────────────────────────────────────────────────────
log_analytics_retention_days = 30
prometheus_retention_days    = 30

# ── ArgoCD ────────────────────────────────────────────────────────────────────
argocd_repo_url        = "https://github.com/DemirEvren/sqli-analyse.git"
argocd_target_revision = "main"
github_username        = "DemirEvren"

# ── DNS ───────────────────────────────────────────────────────────────────────
# Leave empty to use <ingress-ip>.nip.io dynamic DNS (good for testing)
# dns_zone_name = "shelfware.example.com"

# ── Sensitive — pass via env vars, NOT here ───────────────────────────────────
# export TF_VAR_postgres_password="..."
# export TF_VAR_jwt_secret="..."
# export TF_VAR_github_token="ghp_..."
