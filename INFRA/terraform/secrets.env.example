# ─── secrets.env.example ──────────────────────────────────────────────────────
# Copy this file to secrets.env and fill in your real values.
# Then source it before running Terraform:
#
#   cp secrets.env.example secrets.env
#   nano secrets.env                    # fill in your values
#   source secrets.env
#   terraform apply
#
# ⚠  secrets.env is in .gitignore — NEVER commit it to Git.
#
# For GitLab CI/CD, set these as protected CI/CD variables instead:
#   Settings → CI/CD → Variables → Add variable (masked + protected)
# ─────────────────────────────────────────────────────────────────────────────

# ── Terraform secrets (passed as TF_VAR_* environment variables) ──────────────
export TF_VAR_postgres_password=""       # min 16 chars — PostgreSQL password
export TF_VAR_jwt_secret=""              # min 32 chars — JWT signing secret (or: openssl rand -hex 32)
export TF_VAR_github_token=""            # ghp_... — GitHub PAT with read:packages scope

# ── Azure auth (if NOT using `az login`) ──────────────────────────────────────
# export ARM_CLIENT_ID=""
# export ARM_CLIENT_SECRET=""
# export ARM_TENANT_ID=""
# export ARM_SUBSCRIPTION_ID=""

# ── OpenCost Azure Cloud Integration (optional but recommended) ───────────────
# Gives OpenCost real per-VM pricing (RI, spot, EA discounts).
# Requires "Cost Management Reader" role on the subscription.
# If not set, OpenCost uses public on-demand list prices (~30-50% off).
export AZURE_SUBSCRIPTION_ID=""              # same as ARM_SUBSCRIPTION_ID
export AZURE_TENANT_ID=""                    # same as ARM_TENANT_ID
export AZURE_CLIENT_ID=""                    # same SP or a dedicated read-only one
export AZURE_CLIENT_SECRET=""                # SP secret

# ── Bootstrap script also reads these directly ────────────────────────────────
export POSTGRES_PASSWORD="${TF_VAR_postgres_password}"
export JWT_SECRET="${TF_VAR_jwt_secret}"
export GITHUB_TOKEN="${TF_VAR_github_token}"
