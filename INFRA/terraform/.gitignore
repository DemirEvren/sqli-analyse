# ─── Terraform state (managed by Azure Blob) ──────────────────────────────────
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# ─── Sensitive files ──────────────────────────────────────────────────────────
terraform.tfvars          # Real values — use terraform.tfvars.example as template
!terraform.tfvars.example # Keep the example in Git
*.auto.tfvars
backend.conf              # Contains storage account name (generated by bootstrap)
!backend.conf.example     # Keep the example in Gitsecrets.env               # TF_VAR exports — NEVER commit
!secrets.env.example      # Keep the example in Git
# ─── Generated kubeconfigs (written by local_file resource) ───────────────────
kubeconfigs/

# ─── Terraform working directory artifacts ────────────────────────────────────
*.tfplan
override.tf
override.tf.json
*_override.tf
*_override.tf.json
crash.log
crash.*.log

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
